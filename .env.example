# Renomeie este arquivo para .env e preencha com seus dados.
# NUNCA commite o arquivo .env no git!

# Chave privada da carteira de deploy (sem 0x)
PRIVATE_KEY=sua_chave_privada_aqui

# URL do RPC da rede Sepolia (ex: Alchemy, Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/sua_api_key

# API Key do Etherscan (para verificar o contrato, opcional)
ETHERSCAN_API_KEY=sua_api_key_etherscan
